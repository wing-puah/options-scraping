# Barchart credentials
BARCHART_EMAIL=
BARCHART_PASSWORD=

# Google Drive — OAuth2 (personal account, run scripts/auth_drive.py once)
# Download client JSON from: GCP Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_OAUTH_CLIENT_JSON=
GOOGLE_OAUTH_TOKEN_JSON=
# Drive folder ID — from the folder URL: drive.google.com/drive/folders/THIS_PART
GOOGLE_DRIVE_FOLDER_ID=

# Google Sheets — service account (for LLM analysis results + dashboard)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_CONTENT=
# Sheets ID — only needed for LLM analysis results and dashboard
GOOGLE_SPREADSHEET_ID=

# Trade journal (separate sheet from the options data sheet)
TRADE_JOURNAL_SPREADSHEET_ID=


# Scraper settings
COOKIES_PATH=
SCRAPE_HEADLESS=true
